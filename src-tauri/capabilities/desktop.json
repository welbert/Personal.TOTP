{
  "identifier": "desktop-capability",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "global-shortcut:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-image",
    "dialog:allow-save",
    "dialog:allow-open",
    "core:window:allow-hide"
  ]
}
